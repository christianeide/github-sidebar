{
	"name": "Github Sidebar",
	"description": "Make shortcuts to repositories you frequently use on Github. Faster navigation and better control over your repositories.",
	"author": "Christian Gogstad Eide",
	"version": "4.0.0",
	"manifest_version": 3,
	"icons": {
		"16": "images/logo_16.png",
		"32": "images/logo_32.png",
		"48": "images/logo_48.png",
		"128": "images/logo_128.png"
	},
	"permissions": ["storage", "tabs", "alarms"],
	"host_permissions": ["https://github.com/*"],
	"background": {
		"service_worker": "src/background/background.js"
	},
	"content_scripts": [
		{
			"matches": ["https://github.com/*"],
			"js": [
				"src/content-script/loadVisibility.js",
				"src/content-script/index.jsx"
			],
			"css": ["src/content-script/css/index.scss"],
			"run_at": "document_start"
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["*.png"],
			"matches": ["https://github.com/*"]
		}
	]
}
